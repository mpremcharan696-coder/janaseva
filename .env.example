# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="CO"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://schemesetu-nu.vercel.app/"

# VITE_API_URL: The URL where the Express backend is hosted.
# Use http://localhost:5000 for local development, and your deployed URL for production.
VITE_API_URL="http://localhost:5000"

# VITE_GEMINI_API_KEY: Client-side exposed API key for Gemini AI.
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# DATABASE_URL: PostgreSQL connection string (database integration).
DATABASE_URL="your-database-connection-string-here"
